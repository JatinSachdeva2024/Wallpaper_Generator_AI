# Backend (Railway / Render / local)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
POLLINATIONS_API_KEY=
POLLINATIONS_MODEL=flux
SQLITE_PATH=./data/wallpapers.db
# Railway: use /app/data (same folder as volume mount)
# DATA_DIR=/app/data
PORT=3001
AUTO_GENERATE_ON_START=false
ENABLE_CRON=false

# Frontend (Vercel) — URL of your deployed API, including /api
# Example: https://aura-api.up.railway.app/api
VITE_API_URL=

# Optional: restrict CORS to your Vercel domain (comma-separated)
# CORS_ORIGIN=https://your-app.vercel.app
