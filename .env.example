# OpenRouter — daily prompt generation
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat

# SQLite database (local file)
SQLITE_PATH=./data/wallpapers.db

# Firebase project ID (for future Firestore sync — optional)
FIREBASE_PROJECT_ID=your-project-id

# Server
PORT=3001
CRON_SCHEDULE=0 0 * * *
ENABLE_CRON=true
AUTO_GENERATE_ON_START=true
CRON_SECRET=your-secret-for-manual-trigger
POLLINATIONS_DELAY_MS=3000
POLLINATIONS_RETRIES=2
NODE_ENV=production

# Pollinations — get key at https://enter.pollinations.ai (use sk_ for server)
# Docs: https://gen.pollinations.ai/docs
POLLINATIONS_API_KEY=sk_your_key_here
POLLINATIONS_MODEL=flux
