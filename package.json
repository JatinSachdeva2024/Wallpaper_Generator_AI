{
  "name": "ai-wallpaper-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c magenta,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "wait-on http://localhost:3001/api/health -t 30000 && vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "cron:generate": "tsx server/cron.ts",
    "generate:superhero": "tsx scripts/generate-superhero.ts",
    "test:pollinations": "tsx scripts/test-pollinations.ts",
    "start:server": "tsx server/index.ts",
    "start": "npm run build && npm run start:server"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tsx": "^4.21.0"
  }
}
